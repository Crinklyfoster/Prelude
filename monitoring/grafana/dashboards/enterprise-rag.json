{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Enterprise RAG Assistant — System Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Backend",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Request Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(http_requests_total[1m])", "legendFormat": "req/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "P95 Latency",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "PostgreSQL",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 90 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Active Connections",
      "type": "stat",
      "targets": [{ "expr": "pg_stat_activity_count{state='active'}", "legendFormat": "active" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.95 }] }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Cache Hit Ratio",
      "type": "stat",
      "targets": [{ "expr": "pg_stat_database_blks_hit / (pg_stat_database_blks_hit + pg_stat_database_blks_read + 1)", "legendFormat": "cache hit" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "DB Size",
      "type": "stat",
      "targets": [{ "expr": "pg_database_size_bytes{datname='enterprise_rag'}", "legendFormat": "size" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 20,
      "title": "Containers (cAdvisor)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 11 },
      "id": 21,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Container CPU Usage",
      "type": "timeseries",
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total{name=~'enterprise-rag.*'}[1m])", "legendFormat": "{{name}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 11 },
      "id": 22,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Container Memory Usage",
      "type": "timeseries",
      "targets": [{ "expr": "container_memory_usage_bytes{name=~'enterprise-rag.*'}", "legendFormat": "{{name}}" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "tags": ["enterprise-rag"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Enterprise RAG — Overview",
  "uid": "enterprise-rag-overview",
  "version": 1
}
