DATABASE_URL=postgresql://enterprise_user:enterprise_password@postgres:5432/enterprise_rag

APP_NAME=Enterprise RAG Assistant

DEBUG=True

OLLAMA_HOST=http://host.docker.internal:11434

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://172.18.181.108:3000"]

CHROMA_DB_PATH=./chroma_db

TOP_K=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=qwen3:8b


SECRET_KEY=replace_with_a_secure_random_secret


JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

RETRIEVAL_MODE=hybrid

ENABLE_QUERY_REWRITE=true
ENABLE_RERANKER=false
